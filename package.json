{
  "name": "pkmnrank",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:pages": "wrangler pages dev public --d1=DB",
    "deploy": "wrangler pages deploy public",
    "db:create": "wrangler d1 create pkmnrank-ratings",
    "db:migrate": "wrangler d1 execute pkmnrank-ratings --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute pkmnrank-ratings --remote --file=schema.sql",
    "fetch-pokemon": "node scripts/fetchPokemon.js",
    "fetch-forms": "node scripts/fetchForms.js"
  },
